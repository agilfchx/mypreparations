#!/bin/bash
BOLD='\033[1m'
CYAN='\033[36m'
GREEN='\033[32m'
YELLOW='\033[33m'
BLUE='\033[34m'
NC='\033[0m'

printf "\n"
echo -e "${BOLD}${YELLOW}── FTP — ENUMERATION & EXPLOITATION ─────────────────${NC}"
printf "\n"

echo -e "${BOLD}${CYAN}── Connect ──────────────────────────────────────────${NC}"
echo -e "  ${GREEN}ftp <TARGET>${NC}"
echo -e "  ${GREEN}ftp <TARGET> 21${NC}"
echo -e "  Note: Anonymous login credentials:"
echo -e "  Note: anonymous:anonymous  |  anonymous:  |  ftp:ftp"
printf "\n"

echo -e "${BOLD}${CYAN}── FTP Commands ─────────────────────────────────────${NC}"
echo -e "  ${GREEN}passive${NC}              # transfer behind FW/NAT"
echo -e "  ${GREEN}bin${NC}                  # binary mode (executables — ALWAYS set this)"
echo -e "  ${GREEN}get <file>${NC}           # download file"
echo -e "  ${GREEN}mget *${NC}               # download all"
echo -e "  ${GREEN}put <file>${NC}           # upload file"
echo -e "  ${GREEN}mput <file1> <file2>${NC} # upload multiple"
echo -e "  ${GREEN}ls -la${NC}               # list all files"
echo -e "  ${GREEN}pwd${NC}"
printf "\n"

echo -e "${BOLD}${CYAN}── nxc FTP ──────────────────────────────────────────${NC}"
echo -e "  ${GREEN}nxc ftp <TARGET> -u <USER> -p <PASS>${NC}"
echo -e "  ${GREEN}nxc ftp <TARGET> -u <USER> -p <PASS> --dir /${NC}"
echo -e "  ${GREEN}nxc ftp <TARGET> -u <USER> -p <PASS> --get <remote_file> <local_path>${NC}"
printf "\n"

echo -e "${BOLD}${CYAN}── Brute Force ──────────────────────────────────────${NC}"
echo -e "  ${GREEN}hydra -l <USER> -P /usr/share/wordlists/rockyou.txt ftp://<TARGET>${NC}"
echo -e "  ${GREEN}hydra -L users.txt -P passwords.txt ftp://<TARGET>${NC}"
echo -e "  ${GREEN}nxc ftp <TARGET> -u users.txt -p passwords.txt --continue-on-success${NC}"
printf "\n"

echo -e "${BOLD}${CYAN}── Nmap ─────────────────────────────────────────────${NC}"
echo -e "  ${GREEN}nmap -p 21 --script ftp-anon,ftp-bounce,ftp-syst,ftp-vuln* <TARGET>${NC}"
echo -e "  ${GREEN}nmap -p 21 --script ftp-anon <TARGET>${NC}                # check anonymous login"
printf "\n"
echo -e "  ${BLUE}Always use binary mode (bin) before transferring executables — ASCII mode corrupts them${NC}"
printf "\n"

printf "\n"
echo -e "${YELLOW}─────────────────────────────────────────────────────${NC}"
