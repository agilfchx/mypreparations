#!/bin/bash
BOLD='\033[1m'
CYAN='\033[36m'
GREEN='\033[32m'
YELLOW='\033[33m'
BLUE='\033[34m'
NC='\033[0m'

printf "\n"
echo -e "${BOLD}${YELLOW}── HASH — CRACKING REFERENCE ────────────────────────${NC}"
printf "\n"

echo -e "${BOLD}${CYAN}── Hash Type -> Hashcat Mode ────────────────────────${NC}"
echo -e "  ${GREEN}32ed87bdb5fdc5e9cba88547376818d4${NC}          # NTLM               -m 1000"
echo -e "  ${GREEN}admin::DOMAIN:... (NTLMv2)${NC}                # NetNTLMv2          -m 5600"
echo -e "  ${GREEN}admin::WG:... (NTLMv1)${NC}                    # NetNTLMv1          -m 5500"
echo -e "  ${GREEN}\$krb5tgs\$23\$*...*${NC}                         # Kerberoast RC4     -m 13100"
echo -e "  ${GREEN}\$krb5tgs\$17\$*...*${NC}                         # Kerberoast AES128  -m 19700"
echo -e "  ${GREEN}\$krb5tgs\$18\$*...*${NC}                         # Kerberoast AES256  -m 19800"
echo -e "  ${GREEN}\$krb5asrep\$23\$user@...${NC}                    # AS-REP Roast       -m 18200"
echo -e "  ${GREEN}\$DCC2\$10240#user#...${NC}                      # MS-CacheV2 (DCC2)  -m 2100"
echo -e "  ${GREEN}\$6\$salt\$hash${NC}                              # SHA-512crypt Linux -m 1800"
echo -e "  ${GREEN}\$5\$salt\$hash${NC}                              # SHA-256crypt Linux -m 7400"
echo -e "  ${GREEN}\$1\$salt\$hash${NC}                              # MD5crypt Linux     -m 500"
echo -e "  ${GREEN}\$2y\$... or \$2a\$...${NC}                        # bcrypt             -m 3200"
echo -e "  ${GREEN}5f4dcc3b5aa765d61d8327deb882cf99${NC}          # MD5                -m 0"
echo -e "  ${GREEN}aad3b435b51404eeaad3b435b51404ee${NC}          # LM (empty)         -m 3000"
printf "\n"

echo -e "${BOLD}${CYAN}── Hashcat Commands ─────────────────────────────────${NC}"
echo -e "  Note: NTLM:"
echo -e "  ${GREEN}hashcat -m 1000 hashes.txt /usr/share/wordlists/rockyou.txt${NC}"
echo -e "  ${GREEN}hashcat -m 1000 hashes.txt rockyou.txt -r /usr/share/hashcat/rules/best64.rule${NC}"
printf "\n"
echo -e "  Note: NetNTLMv2 - from Responder:"
echo -e "  ${GREEN}hashcat -m 5600 netntlmv2.txt /usr/share/wordlists/rockyou.txt${NC}"
printf "\n"
echo -e "  Note: Kerberoast:"
echo -e "  ${GREEN}hashcat -m 13100 kerb.txt /usr/share/wordlists/rockyou.txt${NC}   # RC4"
echo -e "  ${GREEN}hashcat -m 19700 kerb.txt /usr/share/wordlists/rockyou.txt${NC}   # AES128"
printf "\n"
echo -e "  Note: AS-REP Roast:"
echo -e "  ${GREEN}hashcat -m 18200 asrep.txt /usr/share/wordlists/rockyou.txt${NC}"
printf "\n"
echo -e "  Note: Linux shadow:"
echo -e "  ${GREEN}hashcat -m 1800 shadow.txt rockyou.txt${NC}       # \$6\$"
echo -e "  ${GREEN}hashcat -m 7400 shadow.txt rockyou.txt${NC}       # \$5\$"
printf "\n"

echo -e "${BOLD}${CYAN}── Hashcat Attack Modes ─────────────────────────────${NC}"
echo -e "  ${GREEN}hashcat -m 1000 -a 0 hash.txt wordlist.txt${NC}            # dict (default)"
echo -e "  ${GREEN}hashcat -m 1000 -a 3 hash.txt '?u?l?l?l?d?d?d?d'${NC}     # brute/mask"
echo -e "  ${GREEN}hashcat -m 1000 -a 0 hash.txt wordlist.txt -r best64.rule${NC}  # rule-based"
echo -e "  ${GREEN}hashcat -m 1000 -a 6 hash.txt wordlist.txt '?d?d?d?d'${NC} # wordlist + mask"
printf "\n"
echo -e "  Note: Masks: ?u=upper  ?l=lower  ?d=digit  ?s=special  ?a=all"
printf "\n"

echo -e "${BOLD}${CYAN}── John the Ripper ──────────────────────────────────${NC}"
echo -e "  ${GREEN}john hash.txt --wordlist=/usr/share/wordlists/rockyou.txt${NC}"
echo -e "  ${GREEN}john hash.txt --format=NT --wordlist=rockyou.txt${NC}"
echo -e "  ${GREEN}john hash.txt --format=sha512crypt --wordlist=rockyou.txt${NC}"
echo -e "  ${GREEN}john --show hash.txt${NC}                         # show cracked"
printf "\n"
echo -e "  Note: John conversion helpers:"
echo -e "  ${GREEN}ssh2john id_rsa > id_rsa.hash && john id_rsa.hash --wordlist=rockyou.txt${NC}"
echo -e "  ${GREEN}zip2john archive.zip > zip.hash && john zip.hash --wordlist=rockyou.txt${NC}"
echo -e "  ${GREEN}keepass2john keepass.kdbx > kp.hash && john kp.hash --wordlist=rockyou.txt${NC}"
echo -e "  ${GREEN}unshadow /etc/passwd /etc/shadow > shadow.hash && john shadow.hash${NC}"
printf "\n"

echo -e "${BOLD}${CYAN}── Identify Hash ────────────────────────────────────${NC}"
echo -e "  ${GREEN}hashid -m '<hash>'${NC}                 # -m shows hashcat mode too"
echo -e "  ${GREEN}hash-identifier${NC}                    # interactive"
printf "\n"

echo -e "${BOLD}${CYAN}── Extract NT hash from secretsdump ─────────────────${NC}"
echo -e "  Note: Format: user:RID:LMhash:NThash:::"
echo -e "  ${GREEN}cat ntds.txt | awk -F: '{print \$4}' > ntlm_hashes.txt${NC}"
echo -e "  ${GREEN}hashcat -m 1000 ntlm_hashes.txt rockyou.txt${NC}"
printf "\n"

echo -e "${BOLD}${CYAN}── Key Wordlists ────────────────────────────────────${NC}"
echo -e "  ${GREEN}/usr/share/wordlists/rockyou.txt${NC}"
echo -e "  ${GREEN}/usr/share/seclists/Passwords/Common-Credentials/10-million-password-list-top-100000.txt${NC}"
echo -e "  ${GREEN}cewl http://target.com -d 2 -m 8 -w custom.txt${NC}  # generate from site"
printf "\n"

printf "\n"
echo -e "${YELLOW}─────────────────────────────────────────────────────${NC}"
