printf "\n"

echo -e "${BOLD}${CYAN}── BloodHound Collection ─────────────────────────────${NC}"
echo -e "  ${GREEN}nxc ldap <DC_IP> -u <USER> -p <PASS> --bloodhound --collection All -ns <DC_IP>${NC}"
echo -e "  ${GREEN}bloodhound-ce-python -c all -d <DOMAIN> -ns <DC_IP> -u <USER>@<DOMAIN> -p <PASS>${NC}"
echo -e "  ${GREEN}Invoke-BloodHound -CollectionMethod All,GPOLocalGroup${NC}"
