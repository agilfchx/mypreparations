echo -e "  ${GREEN}Get-DomainComputer -Unconstrained${NC}"
echo -e "  ${GREEN}Get-DomainComputer -TrustedToAuth${NC}"
echo -e "  ${GREEN}Get-ObjectAcl -Identity <TARGET> -ResolveGUIDs${NC}"
echo -e "  ${GREEN}Get-DomainObjectAcl -SamAccountName 'Domain Admins' -ResolveGUIDs | Select IdentityReference,ActiveDirectoryRights${NC}"
echo -e "  ${GREEN}Find-InterestingDomainAcl | select identityreferencename,activedirectoryrights,acetype,objectdn | ft${NC}"
echo -e "  ${GREEN}ConvertFrom-SID S-1-5-21-...${NC}"
