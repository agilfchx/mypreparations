echo -e "  ${GREEN}Get-DomainTrustMapping${NC}"
echo -e "  ${GREEN}Get-DomainForeignGroupMember${NC}"
echo -e "  ${GREEN}Get-ForestDomain${NC}"
echo -e "  ${GREEN}Get-ForestTrust${NC}"
printf "\n"

echo -e "${BOLD}${CYAN}── nxc AD Enum ──────────────────────────────────────${NC}"
echo -e "  ${GREEN}nxc smb <DC_IP> -u <USER> -p <PASS> --users --groups --shares --pass-pol${NC}"
echo -e "  ${GREEN}nxc ldap <DC_IP> -u <USER> -p <PASS> --users --active-users --groups${NC}"
echo -e "  ${GREEN}nxc ldap <DC_IP> -u <USER> -p <PASS> --computers${NC}"
echo -e "  ${GREEN}nxc ldap <DC_IP> -u <USER> -p <PASS> --find-delegation${NC}"
