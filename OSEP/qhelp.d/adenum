echo -e "  ${GREEN}Get-NetGroup | select cn${NC}"
echo -e "  ${GREEN}Get-NetGroupMember 'Domain Admins'${NC}"
echo -e "  ${GREEN}Get-NetComputer | select cn,operatingsystem,dnshostname${NC}"
echo -e "  ${GREEN}Find-LocalAdminAccess${NC}"
echo -e "  ${GREEN}Get-NetSession -ComputerName <HOST> -Verbose${NC}"
echo -e "  ${GREEN}Find-DomainShare${NC}"
echo -e "  ${GREEN}Find-DomainShare -ExcludeStandard -ExcludePrint -ExcludeIPC -CheckShareAccess${NC}"
echo -e "  ${GREEN}Get-DomainUser -SPN${NC}                              # Kerberoastable"
