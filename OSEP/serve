#!/bin/bash

RED='\033[31m'
GREEN='\033[32m'
BLUE='\033[34m'
YELLOW='\033[33m'
NC='\033[0m'

CONFIG="$HOME/.servepaths"
UPLOAD=false
SSL=false
PORT=80
TARGET_DIR="$(pwd)"

usage() {
    echo -e "${RED}Usage: $0 [linux|windows|<dir>] [port] [--upload] [--ssl]${NC}"
    echo -e "${RED}  serve                        # current dir, port 80${NC}"
    echo -e "${RED}  serve 8080                   # current dir, port 8080${NC}"
    echo -e "${RED}  serve linux                  # linux tools dir${NC}"
    echo -e "${RED}  serve linux 8080             # linux tools, port 8080${NC}"
    echo -e "${RED}  serve --upload               # + file upload, HTTP${NC}"
    echo -e "${RED}  serve --upload --ssl         # + file upload, HTTPS${NC}"
    echo -e "${RED}  serve --upload 8080          # + file upload, port 8080${NC}"
    echo -e "${RED}  serve --upload --ssl 8080    # + file upload, HTTPS, port 8080${NC}"
    exit 1
}

load_config() {
    if [ ! -f "$CONFIG" ]; then
        echo -e "${YELLOW}[!] Config not found. Creating $CONFIG${NC}"
        cat > "$CONFIG" <<EOF
LINUX_TOOLS=/path/to/your/Linux/tools
WINDOWS_TOOLS=/path/to/your/Windows/tools
EOF
        echo -e "${YELLOW}[!] Edit $CONFIG then rerun.${NC}"
        exit 1
    fi
    source "$CONFIG"
}

get_ip() {
    local ip
    ip=$(ip addr show tun0 2>/dev/null | grep 'inet ' | awk '{print $2}' | cut -d'/' -f1)
    [ -z "$ip" ] && ip=$(ip addr show eth0 2>/dev/null | grep 'inet ' | awk '{print $2}' | cut -d'/' -f1)
    echo "$ip"
}

# Parse args
for arg in "$@"; do
    case "$arg" in
        --upload) UPLOAD=true ;;
        --ssl)    SSL=true ;;
        linux)    load_config; TARGET_DIR="$LINUX_TOOLS" ;;
        windows)  load_config; TARGET_DIR="$WINDOWS_TOOLS" ;;
        [0-9]*)   PORT="$arg" ;;
        *)
            if [ -d "$arg" ]; then
                TARGET_DIR="$arg"
            else
                echo -e "${RED}Error: '$arg' unknown${NC}"
                usage
            fi
            ;;
    esac
done

# SSL requires --upload
if [ "$SSL" = true ] && [ "$UPLOAD" = false ]; then
    echo -e "${RED}Error: --ssl requires --upload${NC}"
    usage
fi

# Validate dir
if [ ! -d "$TARGET_DIR" ]; then
    echo -e "${RED}Error: Directory '$TARGET_DIR' not found.${NC}"
    exit 1
fi

HOST_IP=$(get_ip)
[ -z "$HOST_IP" ] && HOST_IP="0.0.0.0"

PROTO="http"
[ "$SSL" = true ] && PROTO="https"

echo -e "${GREEN}Serving:  $TARGET_DIR${NC}"
echo -e "${GREEN}URL:      $PROTO://$HOST_IP:$PORT${NC}"
[ "$UPLOAD" = true ] && echo -e "${BLUE}Upload:   enabled${NC}"
[ "$SSL" = true ]    && echo -e "${BLUE}SSL:      enabled (self-signed)${NC}"
echo ""

cd "$TARGET_DIR" || exit 1

if [ "$UPLOAD" = false ]; then
    python3 -m http.server "$PORT"
else
    # Inline upload server
    SSL_FLAG=""
    [ "$SSL" = true ] && SSL_FLAG="--ssl"

    python3 - "$PORT" "$SSL_FLAG" <<'PYEOF'
import os, sys, ssl, tempfile, subprocess
import posixpath, http.server, urllib.parse, urllib.error
import html, shutil, mimetypes, re
from io import BytesIO

PORT = int(sys.argv[1])
USE_SSL = "--ssl" in sys.argv

class UploadHandler(http.server.BaseHTTPRequestHandler):
    def log_message(self, format, *args):
        print(f"[*] {self.client_address[0]} - {format % args}")

    def do_GET(self):
        f = self.send_head()
        if f:
            self.copyfile(f, self.wfile)
            f.close()

    def do_HEAD(self):
        f = self.send_head()
        if f:
            f.close()

    def do_POST(self):
        self.request.settimeout(10000)
        r, info = self.deal_post_data()
        print(f"[+] Upload: {info} from {self.client_address[0]}")
        f = BytesIO()
        f.write(b'<!DOCTYPE html><html><title>Upload Result</title><body>')
        f.write(b'<h2>Upload Result</h2><hr>')
        f.write(b'<strong>Success:</strong> ' if r else b'<strong>Failed:</strong> ')
        f.write(info.encode())
        f.write(f'<br><a href="{self.headers["referer"]}">back</a>'.encode())
        f.write(b'</body></html>')
        length = f.tell(); f.seek(0)
        self.send_response(200)
        self.send_header("Content-type", "text/html")
        self.send_header("Content-Length", str(length))
        self.end_headers()
        self.copyfile(f, self.wfile)
        f.close()

    def deal_post_data(self):
        content_type = self.headers['content-type']
        if not content_type:
            return (False, "No content-type boundary")
        boundary = content_type.split("=")[1].encode()
        remainbytes = int(self.headers['content-length'])
        line = self.rfile.readline(); remainbytes -= len(line)
        if boundary not in line:
            return (False, "Content not begin with boundary")
        line = self.rfile.readline(); remainbytes -= len(line)
        fn = re.findall(r'Content-Disposition.*name="fil.*"; filename="(.*)"', line.decode())
        if not fn:
            return (False, "Unable to locate file for upload")
        path = self.translate_path(self.path)
        fn = os.path.join(path, fn[0])
        self.rfile.readline(); remainbytes -= len(line)
        self.rfile.readline(); remainbytes -= len(line)
        try:
            out = open(fn, 'wb')
        except IOError:
            return (False, "Can't create file — permission denied?")
        preline = self.rfile.readline(); remainbytes -= len(preline)
        while remainbytes > 0:
            line = self.rfile.readline(); remainbytes -= len(line)
            if boundary in line:
                preline = preline.rstrip(b'\r\n')
                out.write(preline); out.close()
                return (True, f"File '{fn}' uploaded!")
            else:
                out.write(preline); preline = line
        return (False, "Unexpected end of data")

    def send_head(self):
        path = self.translate_path(self.path)
        if os.path.isdir(path):
            if not self.path.endswith('/'):
                self.send_response(301)
                self.send_header("Location", self.path + "/")
                self.end_headers()
                return None
            for index in ("index.html", "index.htm"):
                index_path = os.path.join(path, index)
                if os.path.exists(index_path):
                    path = index_path; break
            else:
                return self.list_directory(path)
        ctype = self.guess_type(path)
        try:
            f = open(path, 'rb')
        except IOError:
            self.send_error(404, "File not found"); return None
        self.send_response(200)
        self.send_header("Content-type", ctype)
        fs = os.fstat(f.fileno())
        self.send_header("Content-Length", str(fs[6]))
        self.send_header("Last-Modified", self.date_time_string(fs.st_mtime))
        self.end_headers()
        return f

    def list_directory(self, path):
        try:
            filelist = os.listdir(path)
        except os.error:
            self.send_error(404, "No permission to list directory"); return None
        filelist.sort(key=lambda a: a.lower())
        f = BytesIO()
        displaypath = html.escape(urllib.parse.unquote(self.path))
        f.write(b'<!DOCTYPE html><html>')
        f.write(f'<title>Directory: {displaypath}</title>'.encode())
        f.write(f'<body><h2>Directory: {displaypath}</h2><hr>'.encode())
        f.write(b'<form ENCTYPE="multipart/form-data" method="post">')
        f.write(b'<input name="file" type="file"/>')
        f.write(b'<input type="submit" value="Upload"/></form><hr><ul>')
        for name in filelist:
            fullname = os.path.join(path, name)
            displayname = linkname = name
            if os.path.isdir(fullname):
                displayname = name + "/"; linkname = name + "/"
            if os.path.islink(fullname):
                displayname = name + "@"
            f.write(f'<li><a href="{urllib.parse.quote(linkname)}">{html.escape(displayname)}</a>'.encode())
        f.write(b'</ul><hr></body></html>')
        length = f.tell(); f.seek(0)
        self.send_response(200)
        self.send_header("Content-type", "text/html")
        self.send_header("Content-Length", str(length))
        self.end_headers()
        return f

    def translate_path(self, path):
        path = path.split('?', 1)[0].split('#', 1)[0]
        path = posixpath.normpath(urllib.parse.unquote(path))
        words = [w for w in path.split('/') if w]
        path = os.getcwd()
        for word in words:
            _, word = os.path.split(word)
            if word in (os.curdir, os.pardir): continue
            path = os.path.join(path, word)
        return path

    def copyfile(self, source, outputfile):
        shutil.copyfileobj(source, outputfile)

    def guess_type(self, path):
        if not mimetypes.inited:
            mimetypes.init()
        ext_map = mimetypes.types_map.copy()
        ext_map.update({'': 'application/octet-stream', '.py': 'text/plain'})
        _, ext = posixpath.splitext(path)
        return ext_map.get(ext) or ext_map.get(ext.lower()) or ext_map['']

httpd = http.server.HTTPServer(("0.0.0.0", PORT), UploadHandler)

if USE_SSL:
    tmpdir = tempfile.mkdtemp()
    key = os.path.join(tmpdir, "key.pem")
    crt = os.path.join(tmpdir, "crt.pem")
    subprocess.run([
        "openssl", "req", "-x509", "-newkey", "rsa:2048",
        "-keyout", key, "-out", crt,
        "-days", "1", "-nodes", "-subj", "/CN=serve"
    ], check=True, capture_output=True)
    ctx = ssl.SSLContext(ssl.PROTOCOL_TLS_SERVER)
    ctx.load_cert_chain(crt, key)
    httpd.socket = ctx.wrap_socket(httpd.socket, server_side=True)
    print(f"[+] HTTPS upload server on port {PORT}")
else:
    print(f"[+] HTTP upload server on port {PORT}")

try:
    httpd.serve_forever()
except KeyboardInterrupt:
    print("\n[*] Stopped.")
PYEOF
fi
