TOPIC_DIR="$(dirname "$(realpath "$0")")/qhelp.d"

# Normalize aliases to canonical topic name
normalize_topic() {
    case "$1" in
        upgrade|tty|pty|stable)          echo "shell" ;;
        portscan|scan)                    echo "nmap" ;;
        smbclient|netexec|nxc)           echo "smb" ;;
        ldapdomaindump)                  echo "ldap" ;;
        dnsrecon|dnsenum)                echo "dns" ;;
        onesixtyone|snmpwalk)            echo "snmp" ;;
        gobuster|ffuf|nikto|dirbuster)   echo "web" ;;
        procdump|lsassy)                 echo "lsass" ;;
        secretsdump)                     echo "sam" ;;
        gpp)                             echo "laps" ;;
        hashcat|john)                    echo "hash" ;;
        crack)                           echo "crack" ;;
        sharphound)                      echo "bloodhound" ;;
        kerberoasting|spn)               echo "kerberoast" ;;
        asreproast)                      echo "asrep" ;;
        acl|genericall|genericwrite)     echo "dacl" ;;
        ntds)                            echo "dcsync" ;;
        silver|ticket|krbtgt)            echo "golden" ;;
        ntlmrelay|responder)             echo "relay" ;;
        esc|certipy|certify)             echo "adcs" ;;
        passthehash)                     echo "pth" ;;
        evilwinrm)                       echo "winrm" ;;
        dcom|wmiexec)                    echo "wmi" ;;
        password|spraying)               echo "spray" ;;
        tunnel|pivot)                    echo "ligolo" ;;
        sshtunnel|sshuttle)              echo "ssh" ;;
        pe)                              echo "privesc" ;;
        juicy|printspoofer|godpotato)    echo "potato" ;;
        gtfobins|capabilities|caps)      echo "suid" ;;
        payload|genpayload)              echo "msfvenom" ;;
        bypass|evasion|av)               echo "amsi" ;;
        clm|installutil)                 echo "applocker" ;;
        process|hollowing|dll)           echo "injection" ;;
        sql|xpcmdshell)                  echo "mssql" ;;
        xfreerdp|rdesktop)               echo "rdp" ;;
        kerbrute)                        echo "kerberos" ;;
        *)                               echo "$1" ;;
    esac
}

